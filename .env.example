# Database Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-postgres-setup:p1
DATABASE_URL=postgresql://user:password@localhost:5432/aichat

# Redis Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-redis-setup:p1
REDIS_URL=redis://localhost:6379

# Connection Pool Settings
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-connection-pool:p2
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Auth Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-user-auth-jwt-middleware:p1
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_EXPIRES_IN=24h

# OAuth Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-user-auth-oauth-endpoint:p1
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-chat-core-llm-adapter:p1
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096

# Context Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-chat-core-context-management:p1
CONTEXT_MAX_TOKENS=8000
SYSTEM_PROMPT=You are a helpful AI assistant. Be concise and accurate in your responses. Format code blocks with appropriate language tags for syntax highlighting.

# Rate Limiting Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-chat-core-rate-limiting:p1
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_IP_PER_MIN=100
RATE_LIMIT_ANON_PER_MIN=10

# Moderation Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-content-moderation-input-middleware:p1
MODERATION_ENABLED=true
MODERATION_BLOCK_THRESHOLD=0.8
MODERATION_FLAG_THRESHOLD=0.5
