# Database Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-postgres-setup:p1
DATABASE_URL=postgresql://user:password@localhost:5432/aichat

# Redis Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-redis-setup:p1
REDIS_URL=redis://localhost:6379

# Connection Pool Settings
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-database-foundation-connection-pool:p2
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Auth Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-user-auth-jwt-middleware:p1
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_EXPIRES_IN=24h

# OAuth Configuration
# @cpt-dod:cpt-ai-chat-via-cyber-pilot-dod-user-auth-oauth-endpoint:p1
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
